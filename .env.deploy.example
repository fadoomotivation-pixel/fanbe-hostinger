# ─────────────────────────────────────────────────────────────
# Fanbe Group — Hostinger FTP Deploy Credentials Template
# ─────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:  cp .env.deploy.example .env.deploy
#   2. Fill in your real FTP credentials below
#   3. Run:  npm run deploy
#
# WHERE TO FIND CREDENTIALS:
#   Hostinger hPanel → Hosting → FTP Accounts
#
# ⚠️  IMPORTANT: .env.deploy is gitignored.
#      Never commit your real credentials to GitHub.
# ─────────────────────────────────────────────────────────────

FTP_HOST=ftp.fanbegroup.com
FTP_USER=your_ftp_username
FTP_PASS=your_ftp_password
FTP_REMOTE=/public_html
