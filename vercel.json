{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/crm/assets/:path*", "destination": "/crm/assets/:path*" },
    { "source": "/crm/:path*", "destination": "/crm/index.html" }
  ],
  "redirects": [
    { "source": "/", "destination": "/crm/", "permanent": false }
  ],
  "cleanUrls": true
}
